{
  "entities": {
    "siteConfig": {
      "title": "Site Configuration",
      "description": "Global configuration for the showcase site",
      "type": "object",
      "properties": {
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "whatsappNumber": { "type": "string" }
      },
      "required": ["heroTitle", "heroSubtitle", "whatsappNumber"]
    },
    "portfolioItem": {
      "title": "Portfolio Item",
      "description": "A site in the portfolio",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "url": { "type": "string" },
        "image": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["title", "category", "url", "image"]
    }
  },
  "firestore": {
    "config/main": {
      "schema": "siteConfig",
      "description": "Main site configuration"
    },
    "portfolio": {
      "schema": "portfolioItem",
      "description": "Collection of portfolio items"
    }
  }
}
